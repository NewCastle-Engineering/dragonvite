# ========================================
# Dragonvite Environment Variables
# ========================================

# ========================================
# DATABASE (Supabase PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/dragonvite

# ========================================
# FRONTEND
# ========================================
VITE_API_URL=http://localhost/api
VITE_WS_URL=http://localhost
VITE_LOG_LEVEL=debug

# ========================================
# BACKEND (Fastify)
# ========================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# CORS settings
CORS_ORIGIN=http://localhost

# ========================================
# REDIS (Cache & Job Queue)
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# BULL MQ (Job Queue)
# ========================================
BULLMQ_QUEUE_NAME=dragonvite-jobs
BULLMQ_WORKERS=4

# ========================================
# AUTHENTICATION & SECURITY
# ========================================
# Supabase Auth (optional, if using Supabase auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret for backend auth (if custom auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ========================================
# EXTERNAL SERVICES
# ========================================

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key

# LLM Service (Ollama - Friend's hosted instance)
OLLAMA_API_URL=http://friend-server:11434
OLLAMA_MODEL=llama2

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info

# ========================================
# CODE QUALITY
# ========================================
SONAR_HOST_URL=http://localhost:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin
