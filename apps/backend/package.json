{
  "name": "@dragonvite/backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && echo 'Build complete'",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@dragonvite/database": "workspace:*",
    "@dragonvite/shared": "workspace:*",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.7.0",
    "bullmq": "^5.2.0",
    "fastify": "^4.25.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
